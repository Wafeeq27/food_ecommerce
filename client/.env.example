# Email.js Configuration
# Get these from https://dashboard.emailjs.com/admin

# Your Email.js Public Key (found in Account > API Keys)
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Your Email.js Service ID (create a service in Email.js dashboard)
VITE_EMAILJS_SERVICE_ID=service_xxxxx

# Email.js Template IDs (create these templates in Email.js dashboard)
# Customer confirmation email template
VITE_EMAILJS_CUSTOMER_TEMPLATE_ID=template_customer_xxxxx

# Admin notification email template
VITE_EMAILJS_ADMIN_TEMPLATE_ID=template_admin_xxxxx

# Status update email template
VITE_EMAILJS_STATUS_TEMPLATE_ID=template_status_xxxxx

# Admin email address (where admin emails will be sent)
VITE_ADMIN_EMAIL=admin@khaleel.com

# API Configuration
VITE_API_URL=https://your-backend-url.onrender.com/api
